{
  "compilerOptions": {
    "paths": {
      "@/*": ["./docs/*"]
    },
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "checkJs": true,
    "allowJs": true,
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true
  },
  "include": ["docs/**/*.ts", "docs/**/*.mts", "docs/**/*.vue", "docs/**/*.js"]
}
