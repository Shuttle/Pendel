{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "System.Net.Http": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/.log",
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 1048576,
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "azure": "UseDevelopmentStorage=true;DevelopmentStorageProxyUri=http://azurite",
    "Access": "server=database;database=Access;user id=sa;password=Pass!000;TrustServerCertificate=true"
  },
  "Shuttle": {
    "OAuth": {
      "Providers": {
        "GitHub": {
          "RedirectUri": "http://localhost:3005/oauth",
          "ClientId": "<client-id>",
          "ClientSecret": "<client-secret>",
          "Authorize": {
            "Url": "https://github.com/login/oauth/authorize"
          },
          "Token": {
            "Url": "https://github.com/login/oauth/access_token"
          },
          "Data": {
            "UserAgent": "Shuttle.OAuth/1.0",
            "Url": "https://api.github.com/user",
            "EmailPropertyName": "email",
            "IdentityPropertyName": "email"
          },
          "scope": "user:email",
          "Issuer": {
            "Uri": "https://github.com/login/oauth",
            "JwksUri": "https://api.github.com/meta",
            "IdentityNameClaimTypes": [ "" ]
          }
        },
        "Microsoft": {
          "RedirectUri": "http://localhost:3005/oauth",
          "ClientId": "<client-id>",
          "Authorize": {
            "Url": "https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize",
            "CodeChallengeMethod": "S256"
          },
          "Token": {
            "Url": "https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token",
            "ContentTypeHeader": "application/x-www-form-urlencoded"
          },
          "Data": {
            "Url": "https://graph.microsoft.com/v1.0/me",
            "AuthorizationHeaderScheme": "Bearer",
            "EmailPropertyName": "mail",
            "IdentityPropertyName": "mail"
          },
          "Scope": "User.Read",
          "Issuer": {
            "Uri": "https://sts.windows.net/<tenant-id>/",
            "JwksUri": "https://login.microsoftonline.com/common/discovery/v2.0/keys",
            "IdentityNameClaimTypes": [ "upn", "email" ]
          }
        }
      }
    },
    "Hopper": {
      "Inbox": {
        "WorkTransportUri": "azuresq://azure/access-webapi-inbox-work",
        "DeferredTransportUri": "azuresq://azure/access-webapi-inbox-deferred",
        "ErrorTransportUri": "azuresq://azure/shuttle-error",
        "ThreadCount": 1,
        "IgnoreOnFailureDurations": [
          "00:00:05",
          "00:00:10",
          "00:00:30"
        ]
      },
      "MessageRoutes": [
        {
          "Uri": "azuresq://azure/access-server-inbox-work",
          "Specifications": [
            {
              "Name": "StartsWith",
              "Value": "Shuttle.Access.Messages"
            }
          ]
        }
      ]
    }
  }
}